# Public DSN for client-side error reporting (optional).
VITE_SENTRY_DSN=

# Release identifier used for Sentry release correlation (optional).
# Example: git SHA, semantic version, or CI build number.
VITE_APP_RELEASE=

# Server-side forwarding for Content-Security-Policy violation reports collected
# at /api/csp-report (optional; set in the Vercel project, NEVER exposed to the
# client). Set one of the following to forward reports:
#   CSP_REPORT_URI: explicit collector URL (takes precedence)
#   SENTRY_DSN:     server-side DSN; the Sentry security endpoint is derived from it
# When neither is set, reports are accepted and dropped so the CSP stays valid.
CSP_REPORT_URI=
SENTRY_DSN=

# Optional per-instance guard for accepted CSP reports. Defaults to 120 valid
# reports per minute. Set to 0 to disable.
CSP_REPORT_MAX_PER_MINUTE=
