{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["vite/client"],
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "paths": {
      "roughjs/bundled/rough.esm.js": ["../node_modules/roughjs/bundled/rough.d.ts"]
    }
  },
  "include": ["../web/src/**/*.js"],
  "exclude": ["../web/dist/**", "../web/e2e/**", "../coverage/**", "../node_modules/**"]
}
