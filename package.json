{
  "name": "linkedin-analyzer-web",
  "version": "0.5.0",
  "description": "Web interface for LinkedIn CSV data cleaner and analyzer",
  "author": "Aditya Kumar Darak",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite --config web/vite.config.js",
    "build": "vite build --config web/vite.config.js",
    "preview": "vite preview --config web/vite.config.js",
    "format": "prettier --config config/prettierrc.json --ignore-path config/prettierignore --no-error-on-unmatched-pattern --write \"*.{json,md,yml,yaml}\" \"config/**/*.{json,js,mjs,yml,yaml}\" \"docs/**/*.md\" \".github/**/*.{json,md,yml,yaml,mjs}\" \"scripts/**/*.{js,mjs}\" \"web/*.config.js\" \"web/**/*.json\"",
    "format:check": "prettier --config config/prettierrc.json --ignore-path config/prettierignore --no-error-on-unmatched-pattern --check \"*.{json,md,yml,yaml}\" \"config/**/*.{json,js,mjs,yml,yaml}\" \"docs/**/*.md\" \".github/**/*.{json,md,yml,yaml,mjs}\" \"scripts/**/*.{js,mjs}\" \"web/*.config.js\" \"web/**/*.json\"",
    "lint": "eslint --config config/eslint.config.mjs \"web/src/**/*.js\" \"web/tests/**/*.js\" \"api/**/*.mjs\"",
    "typecheck:web": "tsc --noEmit --project config/jsconfig.json",
    "test": "vitest run --config web/vitest.config.js --coverage",
    "test:e2e": "playwright test --config config/playwright.config.js",
    "test:e2e:headed": "playwright test --config config/playwright.config.js --headed",
    "test:e2e:install": "playwright install chromium firefox webkit",
    "test:e2e:ui": "playwright test --config config/playwright.config.js --ui",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "ci:web": "make ci-web",
    "dead-code": "knip --config config/knip.json",
    "check:overrides": "node scripts/check-overrides.mjs",
    "lint:workflows": "node scripts/lint/lint-workflows.mjs"
  },
  "keywords": [
    "linkedin",
    "csv",
    "excel",
    "data-cleaning",
    "web-app"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Hermione-Granger-1176/linkedin-analyzer"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "dependencies": {
    "@sentry/browser": "^10.63.0",
    "roughjs": "^4.6.6",
    "web-vitals": "^5.3.0",
    "write-excel-file": "^4.1.1"
  },
  "size-limit": [
    {
      "path": "web/dist/assets/index-*.js",
      "limit": "500 kB"
    },
    {
      "path": "web/dist/assets/index-*.css",
      "limit": "50 kB"
    },
    {
      "path": "web/dist/assets/analytics-worker-*.js",
      "limit": "13 kB"
    },
    {
      "path": "web/dist/assets/connections-worker-*.js",
      "limit": "6 kB"
    },
    {
      "path": "web/dist/assets/messages-worker-*.js",
      "limit": "8 kB"
    }
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@size-limit/file": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "actionlint": "2.0.6",
    "eslint": "^10.6.0",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "fake-indexeddb": "^6.1.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "prettier": "^3.9.4",
    "size-limit": "^12.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18"
  }
}
